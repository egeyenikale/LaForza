# Frontend server configuration. Browser requests use the same-origin /backend
# rewrite, so do not expose Redis credentials or WDK secrets to NEXT_PUBLIC_*.
BACKEND_API_ORIGIN=http://127.0.0.1:4000
# Optional escape hatch for a direct API URL. Usually leave unset.
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api/v1

# Backend configuration
HOST=127.0.0.1
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# One-command local demo
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
DATA_DIR=./.data
STORAGE_PREFIX=laforza:local

# Required by the Vercel backend. Add Upstash Redis through Vercel Marketplace.
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Required on Vercel. Generate a unique 32+ character secret; never expose it
# to the frontend or reuse the local example value.
WDK_VAULT_PASSPHRASE=laforza-local-demo

# The backend defaults to Hardhat account #0 only for the local demo.
# Never reuse that public test key or commit funded keys for a live network.
